{
  "info": {
    "name": "baFive API Testing",
    "description": "Complete API endpoint testing collection for baFive backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"TestPassword123!\",\n  \"name\": \"New User\",\n  \"department\": \"Engineering\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@bafive.com\",\n  \"password\": \"demo123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile (Protected)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Profile Discovery",
      "item": [
        {
          "name": "Get Random Profiles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/profiles/random?limit=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "profiles", "random"],
              "query": [
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "Get Profile by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/profiles/:profileId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "profiles", ":profileId"],
              "variable": [
                {
                  "key": "profileId",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Search Profiles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/profiles/search?query=john&department=Engineering",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "profiles", "search"],
              "query": [
                {
                  "key": "query",
                  "value": "john"
                },
                {
                  "key": "department",
                  "value": "Engineering"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Connections & Matching",
      "item": [
        {
          "name": "Like Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileId\": \"uuid-of-profile-to-like\",\n  \"action\": \"like\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/connections/like",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "connections", "like"]
            }
          }
        },
        {
          "name": "Pass on Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileId\": \"uuid-of-profile-to-pass\",\n  \"action\": \"pass\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/connections/like",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "connections", "like"]
            }
          }
        },
        {
          "name": "Get Matched Connections",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/connections/matches",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "connections", "matches"]
            }
          }
        },
        {
          "name": "Get All Connections",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/connections",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "connections"]
            }
          }
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"uuid-of-recipient\",\n  \"content\": \"Hey, I'd love to connect!\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/messages",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "messages"]
            }
          }
        },
        {
          "name": "Get Conversations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/messages/conversations",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "messages", "conversations"]
            }
          }
        },
        {
          "name": "Get Messages by Conversation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/messages/conversation/:conversationId",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "messages", "conversation", ":conversationId"],
              "variable": [
                {
                  "key": "conversationId",
                  "value": ""
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
